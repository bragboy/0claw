# Copy to .env and fill in. `.env` is gitignored.

# --- OpenCode Zen (OpenAI-compat, https://opencode.ai/zen/v1) ---
# Paste your opencode-zen key. ZeroClaw uses this via the native
# `opencode-zen` provider — no custom URL config required.
OPENCODE_API_KEY=

# Optional: override the default model. Any id from
# GET https://opencode.ai/zen/v1/models works. Starter list includes
# claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-sonnet-4-5.
# ZEROCLAW_DEFAULT_MODEL=claude-sonnet-4-5

# --- Persona ---
# The name the agent answers to. Personality (voice, style, user context) is
# baked into init-zen.sh and version-controlled; only the name lives here so
# you can rename the assistant without touching the repo.
AGENT_NAME=Reshma

# --- Autonomy ---
# Controls how much the agent can do without asking. Values:
#   supervised (default) — medium/high-risk commands prompt for approval,
#                          all commands allowed but risk gates apply.
#   full                 — kitchen-sink unrestricted: all commands, no
#                          approval gates, no rate/cost caps, no forbidden
#                          paths. Only use inside a disposable sandbox
#                          (e.g. this Docker container) — the agent can
#                          read the container's env, write to mounted
#                          volumes, and reach the internet freely.
#   read_only            — agent observes, does not act.
AUTONOMY_LEVEL=supervised

# --- Telegram ---
# Create a bot with @BotFather and paste the HTTP API token here.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id (get it from @userinfobot). Only this user
# is allowed to DM the agent — anyone else hits the pairing flow.
TELEGRAM_ALLOWED_USER_ID=

# --- Optional: Claude Code CLI (bundled in the image) ---
# Claude Code needs an Anthropic endpoint; opencode-zen is OpenAI-compat, so
# `claude` inside the container uses its own credentials. Leave blank if you
# don't plan to use the bundled CLI.
# ANTHROPIC_API_KEY=

# --- Optional: Gemini CLI (bundled in the image) ---
# GEMINI_API_KEY=
