# Copy to .env and fill in. `.env` is gitignored.

# --- DeepSeek via its Anthropic-compatible endpoint ---
# Paste your DeepSeek API key from https://platform.deepseek.com/. ZeroClaw
# routes through https://api.deepseek.com/anthropic using the native
# `anthropic-custom:<url>` provider, so DeepSeek models are callable over the
# standard Anthropic protocol. init-deepseek.sh also sets
# `[thinking] default_level = "off"` to keep deepseek-v4-flash in
# non-thinking mode (every reasoning token is billed as an output token).
DEEPSEEK_API_KEY=

# Optional: override the default model. deepseek-v4-flash is the unified
# successor to deepseek-chat (non-thinking) and deepseek-reasoner (thinking).
# Both legacy names are deprecated 2026/07/24. With thinking forced off in
# config, v4-flash behaves like the cheap chat model.
# ZEROCLAW_DEFAULT_MODEL=deepseek-v4-flash

# --- Web search (Brave Search API) ---
# Grab a key at https://api.search.brave.com/app/keys. The free "Data for
# Search" tier gives $5/mo in credits (~1500-1700 queries) with no overage
# risk as long as "Override Monthly Spend Limit" stays unchecked. Without
# this key, the built-in web_search tool falls back to DuckDuckGo, which
# aggressively blocks data-center IPs (you'll get captcha HTML instead of
# results).
BRAVE_API_KEY=

# --- Persona ---
# The name the agent answers to. Personality (voice, style, user context) is
# baked into init-deepseek.sh and version-controlled; only the name lives here so
# you can rename the assistant without touching the repo.
AGENT_NAME=Rebecca

# Your local IANA timezone. Baked into USER.md so the agent assumes this zone
# whenever you give times without one, and passes --tz <this> when scheduling
# cron jobs. Examples: Europe/Madrid, America/New_York, Asia/Kolkata, UTC.
USER_TIMEZONE=UTC

# --- Autonomy ---
# Controls how much the agent can do without asking. Values:
#   supervised (default) - medium/high-risk commands prompt for approval,
#                          all commands allowed but risk gates apply.
#   full                 - kitchen-sink unrestricted: all commands, no
#                          approval gates, no rate/cost caps, no forbidden
#                          paths. Only use inside a disposable sandbox
#                          (e.g. this Docker container), the agent can
#                          read the container's env, write to mounted
#                          volumes, and reach the internet freely.
#   read_only            - agent observes, does not act.
AUTONOMY_LEVEL=supervised

# --- Telegram ---
# Create a bot with @BotFather and paste the HTTP API token here.
TELEGRAM_BOT_TOKEN=

# Numeric Telegram user ids allowed to DM the agent. Comma-separated for
# multiple users, e.g. "100116514,47946531". Anyone else is silently
# ignored (warning in logs). Pull an id from your own bot's getUpdates:
#   curl "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates"
TELEGRAM_ALLOWED_USER_ID=

# --- Optional: Gemini CLI (bundled in the image) ---
# GEMINI_API_KEY=
