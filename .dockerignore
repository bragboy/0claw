# Per-tenant runtime state and secrets, must never enter the build context.
tenants/

# Legacy single-tenant paths (kept until everyone has migrated).
.env
.env.*
!.env.example
config/
workspace/

# Repo metadata and developer tooling not needed at runtime.
.git/
.gitignore
.dockerignore
deploy.rb
CLAUDE.md
README.md
assets/

# Noise.
*.log
.DS_Store
